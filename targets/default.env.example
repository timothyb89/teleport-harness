# Copy to targets/default.env (gitignored) and fill in. Loaded by bin/cluster.
#
# The harness gives every disposable cluster a name like
#   <cluster-id>.lab.<HARNESS_DOMAIN>
# so you need a WILDCARD DNS record you control:
#   *.lab.<HARNESS_DOMAIN>   A   127.0.0.1
# (a public record pointing at loopback — resolvable everywhere, no local DNS setup).
#
# TLS is a single wildcard Let's Encrypt cert for *.lab.<HARNESS_DOMAIN>, obtained via
# DNS-01 (no inbound needed), issued once into a persistent volume and reused by every
# cluster. Publicly trusted -> browser + tsh need no CA import.

# Base domain you control (the harness uses the *.lab.<domain> subdomain).
HARNESS_DOMAIN=example.com

# DNS-01 provider for the ACME challenge. Currently: cloudflare (pluggable).
DNS_PROVIDER=cloudflare

# Cloudflare API token, scoped to Zone:DNS:Edit for the zone above.
# Create at https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# ACME contact + directory. Production by default (issue-once keeps rate limits safe).
ACME_EMAIL=you@example.com
# ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory   # default (prod)

# Host port the shared ingress publishes (proxy reachable at
# https://<id>.lab.<domain>:<INGRESS_PORT>). 443 possible via lima; 8443 needs no privilege.
INGRESS_PORT=8443

# TLS provider: le-dns01 (default) or mkcert (offline / no-domain fallback).
TLS_PROVIDER=le-dns01
