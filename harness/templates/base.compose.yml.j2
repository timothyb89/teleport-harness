{# Base cluster scaffold: the auth+proxy service, shared networks, base volumes.
   The renderer (harness/render.py) deep-merges each component/module `services.yml.j2`
   fragment's services + volumes into this, so a cluster = base + components + modules.
   auth_env is the union of every unit's `auth_env`; bootstrap resources + bots are
   collected into $OUT/bootstrap and applied by the shared auth-entrypoint. #}
name: teleport-harness-{{ cluster_id }}

services:
  auth:
    image: {{ image }}
    platform: linux/amd64
    container_name: {{ cluster_id }}-auth
    entrypoint: ["/scripts/auth-entrypoint.sh"]
    {% if auth_env is defined and auth_env %}
    environment:
      {% for k, v in auth_env.items() %}
      {{ k }}: "{{ v }}"
      {% endfor %}
    {% endif %}
    volumes:
      - harness-certs:/certs:ro
      - {{ out }}/config/auth.yaml:/etc/teleport/auth.yaml:ro
      - {{ out }}/bootstrap:/bootstrap:ro
      # apply-on-startup resources handed to `teleport start --apply-on-startup` (teleport
      # applies them itself on every boot). Read-WRITE on purpose: a module's checks may
      # rewrite the applied YAML in place (via docker exec) and restart auth to prove
      # re-apply behavior (e.g. bound_keypair status preservation / discard).
      - {{ out }}/apply-on-startup:/apply-on-startup
      - {{ shared_scripts }}/auth-entrypoint.sh:/scripts/auth-entrypoint.sh:ro
      {% if license_file is defined and license_file %}
      # Enterprise builds need a license; mounted read-only next to auth.yaml and
      # referenced by auth_service.license_file (see auth.yaml.j2). OSS builds omit this.
      - {{ license_file }}:/etc/teleport/license.pem:ro
      {% endif %}
      - auth-data:/var/lib/teleport
    networks:
      internal:
        aliases: ["{{ fqdn }}"]
      teleport-harness:
        aliases: ["{{ fqdn }}"]
    # Healthy only once teleport answers /healthz AND the entrypoint has finished
    # bootstrapping. Dependent bots/agents `depends_on: service_healthy`, so this
    # closes the race where a bot tried to join before its user/token existed.
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:3000/healthz && test -f /tmp/bootstrap-done"]
      interval: 5s
      timeout: 3s
      retries: 40
      start_period: 10s

networks:
  internal:
  teleport-harness:
    external: true
    name: teleport-harness

volumes:
  auth-data:
  harness-certs:
    external: true
    name: harness-certs
