{# Shared teleport auth+proxy config (was byte-identical auth.yaml.tmpl in every
   module). A module can override by providing its own config/auth.yaml.j2. #}
version: v3
teleport:
  nodename: auth
  data_dir: /var/lib/teleport
  diag_addr: 0.0.0.0:3000
  log: {output: stderr, severity: INFO}
  # Emit audit events as newline-delimited JSON on disk (in addition to the text log),
  # so checks can inspect the FULL structured event (the `audit_event` verb renders it
  # as pretty JSON proof) instead of scraping the text logger. One file per day under
  # the dir; each line is one event.
  storage:
    type: sqlite
    audit_events_uri: ["file:///var/lib/teleport/audit/events"]
auth_service:
  enabled: "yes"
  cluster_name: {{ fqdn }}
  listen_addr: 0.0.0.0:3025
  proxy_listener_mode: multiplex
  {% if license_file is defined and license_file %}
  # Enterprise builds require a license; the file is mounted by base.compose.yml.j2.
  license_file: /etc/teleport/license.pem
  {% endif %}
proxy_service:
  enabled: "yes"
  web_listen_addr: 0.0.0.0:{{ port }}
  public_addr: ["{{ fqdn }}:{{ port }}"]
  https_keypairs:
    - key_file: /certs/wildcard.key
      cert_file: /certs/wildcard.crt
ssh_service: {enabled: "no"}
