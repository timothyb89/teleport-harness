{# kubernetes join: two bots join with k8s SA JWTs minted from the shared oidc-server,
   one validated via `oidc` (caching validator) and one via `static_jwks`. Each bot's
   entrypoint mints its SA token to a file and points tbot at it via KUBERNETES_TOKEN_PATH. #}
{% set oidc_host = 'oidc.' ~ lab_domain %}
services:
  # oidc type: teleport fetches issuer discovery+JWKS at join (shared caching validator).
  kube-oidc:
    image: {{ image }}
    platform: linux/amd64
    container_name: {{ cluster_id }}-kube-oidc
    entrypoint: ["/scripts/bot-entrypoint.sh"]
    environment:
      OIDC_URL: https://{{ oidc_host }}:8443
      NAMESPACE: default
      SERVICE_ACCOUNT: kube-oidc-sa
    volumes:
      - {{ out }}/config/tbot-oidc.yaml:/etc/tbot.yaml:ro
      - {{ module_dir }}/scripts:/scripts:ro
    networks: [internal]
    depends_on:
      auth: {condition: service_healthy}

  # static_jwks type: token embeds the JWKS; no fetch at join.
  kube-jwks:
    image: {{ image }}
    platform: linux/amd64
    container_name: {{ cluster_id }}-kube-jwks
    entrypoint: ["/scripts/bot-entrypoint.sh"]
    environment:
      OIDC_URL: https://{{ oidc_host }}:8443
      NAMESPACE: default
      SERVICE_ACCOUNT: kube-jwks-sa
    volumes:
      - {{ out }}/config/tbot-jwks.yaml:/etc/tbot.yaml:ro
      - {{ module_dir }}/scripts:/scripts:ro
    networks: [internal]
    depends_on:
      auth: {condition: service_healthy}
