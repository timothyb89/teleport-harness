{# Positive join: JWT sub=tf-oidc-subject (satisfies allow_any) + the oidc-server's default
   org=ethernet-fyi (satisfies must_match_fields once enforced). Joins in both states. #}
version: v3
teleport:
  nodename: {{ cluster_id }}-tf-agent-ok
  data_dir: /var/lib/teleport
  proxy_server: {{ fqdn }}:{{ port }}
  log: {output: stderr, severity: INFO}
  join_params:
    method: generic_oidc
    token_name: tf-oidc-token
    generic_oidc:
      command: ["curl", "-fsSk", "https://oidc:8443/token?sub=tf-oidc-subject"]
auth_service: {enabled: "no"}
proxy_service: {enabled: "no"}
ssh_service:
  enabled: "yes"
  labels: {test: terraform-generic-oidc, variant: ok}
